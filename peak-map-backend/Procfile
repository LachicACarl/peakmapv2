# Heroku Procfile for PEAK MAP Backend
# This file tells Heroku how to run your application

# Web process (backend API)
web: gunicorn -w 4 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --timeout 120 --access-logfile - --error-logfile - app.main:app

