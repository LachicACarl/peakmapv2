# ========================================
# PEAK MAP Backend Environment Variables
# ========================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit .env to version control (already in .gitignore)
#
# For production deployment (Render/Heroku), add these as environment
# variables in the deployment platform dashboard.

# ========================================
# Supabase Configuration
# ========================================
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (ends with .supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose in frontend)
SUPABASE_KEY=your_anon_key_here

# Service role key (KEEP SECRET! Has admin privileges)
# Only use this in backend, never expose to frontend
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ========================================
# Optional: Database Direct Connection
# ========================================
# Only needed if you want direct PostgreSQL access
# Get from: Supabase Dashboard → Project Settings → Database

# DATABASE_URL=postgresql://postgres:your_password@db.your_project_id.supabase.co:5432/postgres

# ========================================
# Optional: Firebase Admin SDK (if using)
# ========================================
# Path to Firebase service account JSON file
# FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk-key.json

# ========================================
# Server Configuration (Production)
# ========================================
# Port (Render/Heroku auto-set this, leave blank for local)
# PORT=8001

# Environment (development, staging, production)
# ENVIRONMENT=production

# ========================================
# CORS Configuration (Production)
# ========================================
# Frontend URLs that can access this API (comma-separated)
# ALLOWED_ORIGINS=https://your-app.netlify.app,https://your-domain.com

# ========================================
# Optional: GPS/Maps Configuration
# ========================================
# If using any external map/routing APIs
# GOOGLE_MAPS_API_KEY=your_google_maps_key
# MAPBOX_ACCESS_TOKEN=your_mapbox_token
